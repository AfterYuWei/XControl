{
  "name": "xcontrol-desktop",
  "version": "1.0.0",
  "description": "XControl 桌面版 - 基于 Electron 的 SSH 终端",
  "main": "main.js",
  "author": "yuweinfo",
  "license": "MIT",
  "homepage": "https://github.com/AfterYuWei/XControl",
  "repository": {
    "type": "git",
    "url": "https://github.com/AfterYuWei/XControl.git"
  },
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:dir": "electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.yuweinfo.xcontrol",
    "productName": "XControl",
    "copyright": "Copyright © yuweinfo",
    "directories": {
      "output": "release"
    },
    "publish": null,
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "extraResources": [
        {
          "from": "../server/xcontrol-server.exe",
          "to": "xcontrol-server/xcontrol-server.exe"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "XControl-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "XControl",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "extraResources": [
        {
          "from": "../server/xcontrol-server",
          "to": "xcontrol-server/xcontrol-server"
        }
      ],
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "XControl-${version}-${arch}.${ext}"
    },
    "linux": {
      "maintainer": "yuweinfo <dev@yuweinfo.com>",
      "extraResources": [
        {
          "from": "../server/xcontrol-server",
          "to": "xcontrol-server/xcontrol-server"
        }
      ],
      "target": [
        { "target": "deb", "arch": ["x64"] },
        { "target": "rpm", "arch": ["x64"] }
      ],
      "category": "Development",
      "artifactName": "XControl-${version}-${arch}.${ext}"
    }
  }
}
